# Cortex AI Agent — API Keys Template
# Copy this file to .env and fill in your keys

# DeepSeek (get from https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sk-your-key-here

# Together AI (get from https://api.together.ai/settings/api-keys)
TOGETHER_API_KEY=key-your-key-here

# SiliconFlow (get from https://cloud.siliconflow.cn/)
# SILICONFLOW_API_KEY=your-key-here

# If no key is set, the app uses Mock mode (no real AI, but fully functional UI)
