# Cortex IDE Environment Configuration
# Copy this to .env and fill in your values

# ==================== Backend API ====================
# Your website backend URL
CORTEX_API_URL=https://logic-practice.com/api

# ==================== LLM Provider API Keys ====================
# These keys are used by your backend to route requests to LLM providers

# OpenAI (GPT-3.5, GPT-4)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (Claude 3)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# DeepSeek (DeepSeek Coder)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Google Gemini (optional)
GEMINI_API_KEY=your-gemini-key-here

# ==================== JWT Configuration ====================
# Secret key for signing JWT tokens (generate with: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Token expiration time (in seconds)
JWT_EXPIRATION=3600

# ==================== Optional Settings ====================
# Enable debug mode (development only)
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
