# Cortex AI Agent IDE

# Mistral AI — PRIMARY provider (required)
# Get from: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=kUqcDhAVxV6RxJXTGUGi9EGwi7bMUEla

# SiliconFlow — Vision model support (optional)
# Get from: https://cloud.siliconflow.cn/
# SILICONFLOW_API_KEY=your-siliconflow-key-here

# General Settings
CORTEX_DEBUG=True
CORTEX_LOG_LEVEL=DEBUG
CORTEX_MAX_TOKENS=4096
CORTEX_TEMPERATURE=0.7

# Window Settings
CORTEX_WINDOW_WIDTH=1400
CORTEX_WINDOW_HEIGHT=900
CORTEX_SIDEBAR_WIDTH=260
CORTEX_RIGHT_PANEL_WIDTH=320

# Editor Settings
CORTEX_EDITOR_FONT_FAMILY=Courier New
CORTEX_EDITOR_FONT_SIZE=13
CORTEX_EDITOR_TAB_SIZE=4
CORTEX_EDITOR_WORD_WRAP=False
CORTEX_EDITOR_LINE_NUMBERS=True
CORTEX_EDITOR_HIGHLIGHT_CURRENT_LINE=True
CORTEX_EDITOR_AUTO_INDENT=True

# AI Model Settings
CORTEX_DEFAULT_AI_MODEL=mistral-large-latest
CORTEX_DEFAULT_AI_PROVIDER=mistral
CORTEX_AI_AUTO_VERIFY=True
CORTEX_AI_MAX_VERIFY_RETRIES=2

# Recent Projects (comma-separated)
CORTEX_RECENT_PROJECTS=

# Last Project
CORTEX_LAST_PROJECT=

# Theme
CORTEX_THEME=dark